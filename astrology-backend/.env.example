# Environment variables example

# AstrologyAPI credentials
ASTROLOGYAPI_USER_ID=your_astrology_api_user_id
ASTROLOGYAPI_API_KEY=your_astrology_api_key

# Primary LLM — Gemini (gemini-2.5-flash)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Fallback LLM — OpenRouter (google/gemma-4-31b-it:free)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/astrology_db
REDIS_URL=redis://localhost:6379

# App
CORS_ORIGINS=http://localhost:5173
APP_ENV=development
GEMINI_TRANSLATION_KEY=your_gemini_translation_key_here

# Google Authentication
GOOGLE_CLIENT_ID=your_google_client_id_here
JWT_SECRET=your_jwt_secret_here
